# ── Frontend (Vite exposes only VITE_* vars to the browser) ──────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Server-side only (Vercel serverless functions, never sent to browser) ─────
# Required by api/risk/check.ts and api/webhooks/test.ts.
# Get this from Supabase → Project Settings → API → service_role key.
# NEVER commit or expose this value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Vercel also reads SUPABASE_URL as the preferred server-side name.
# Set this alongside VITE_SUPABASE_URL for stricter separation.
# SUPABASE_URL=https://your-project.supabase.co

# ── Optional: AI summaries ────────────────────────────────────────────────────
# When set, risk check responses will use GPT-4o-mini summaries instead of
# the built-in template engine. Falls back gracefully if missing or on error.
# OPENAI_API_KEY=sk-...

# ── Stripe billing (api/billing/*) ────────────────────────────────────────────
# Get these from your Stripe dashboard (https://dashboard.stripe.com).
# Without these vars the Billing tab still renders but Upgrade buttons return 503.
# STRIPE_SECRET_KEY=sk_live_...          # or sk_test_... for testing
# STRIPE_WEBHOOK_SECRET=whsec_...        # from Stripe Dashboard → Webhooks → endpoint secret
# STRIPE_PRICE_STARTER=price_...         # Monthly Price ID for Starter plan
# STRIPE_PRICE_PRO=price_...             # Monthly Price ID for Pro plan

# ── Upstash Redis — per-API-key rate limiting (api/_lib/rateLimit.ts) ─────────
# Without these vars, rate limiting is disabled (fail-open) — API works normally.
# Create a free database at https://console.upstash.com
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── Cron auth (api/webhooks/retry-due, api/cron/maintenance) ─────────────────
# Manual cron triggers require: Authorization: Bearer <value>
# Vercel Cron calls are always allowed via x-vercel-cron: 1 (set automatically).
# CRON_SECRET=your-cron-secret-here

# ── Load test safety flags (api/risk/check.ts) ────────────────────────────────
# Set to "1" to disable side effects during load testing. Unset (or any other
# value) restores normal behaviour. Never enable these in production.
# LOAD_TEST_MODE=1
# DISABLE_WEBHOOKS_DURING_LOAD_TEST=1
# DISABLE_AI_DURING_LOAD_TEST=1

# ── Resend — beta invite emails (api/admin/invites.ts, api/admin/invite-resend.ts) ──
# Without RESEND_API_KEY, invite creation still works but no email is sent.
# Get your key at https://resend.com/api-keys
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL="Genuinux Beta <beta@genuinux.com>"   # must be a verified Resend sender
# BETA_REPLY_TO_EMAIL=beta@genuinux.io
# APP_URL=https://genuinux.com                            # base URL for signup links in emails

# ── Sentry error monitoring ───────────────────────────────────────────────────
# Backend (api/_lib/monitoring.ts): install @sentry/node, then set SENTRY_DSN.
# Frontend (src/lib/monitoring.ts): install @sentry/react, then set VITE_SENTRY_DSN.
# Without these vars the app works normally using structured console logging.
# SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
# VITE_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
